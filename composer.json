{
    "name": "williamjulianvicary/ogify",
    "version": "1.0.0",
    "description": "Driver-based OG image generation for Laravel with Cloudflare Browser Rendering and Browsershot support.",
    "keywords": ["laravel", "og-image", "open-graph", "cloudflare", "browser-rendering", "social-media"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "William Julian-Vicary",
            "email": "will@julian-vicary.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0 || ^12.0 || ^13.0",
        "illuminate/database": "^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^11.0 || ^12.0 || ^13.0",
        "illuminate/queue": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.29.0",
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^3.0 || ^5.0",
        "phpstan/phpstan": "^2.1",
        "rector/rector": "^2.3",
        "spatie/browsershot": "^5.2"
    },
    "suggest": {
        "spatie/browsershot": "Required for the Browsershot driver (^4.0)"
    },
    "autoload": {
        "psr-4": {
            "WilliamJulianVicary\\Ogify\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WilliamJulianVicary\\Ogify\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "WilliamJulianVicary\\Ogify\\OgImageServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "lint": "pint",
        "refactor": "rector",
        "test:lint": "pint --test",
        "test:unit": "pest",
        "test:types": "phpstan",
        "test:refactor": "rector --dry-run",
        "test": [
            "@test:lint",
            "@test:unit",
            "@test:types",
            "@test:refactor"
        ]
    }
}
